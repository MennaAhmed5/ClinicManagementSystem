@model AppointmentAddVM

@{
    SelectList doctorsList = new SelectList(ViewBag.Doctors, "Id", "Name");
}

<h2>Create Appointment</h2>

<form asp-action="Add" asp-controller="Appointment" method="post">
<div class="row">
    <div class="col-sm-6">
            <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="card-header">
                    <strong>Patient Information</strong>
                </div>
                <div class="mb-3">
                    <label asp-for="Patient.Name" class="form-label"></label>
                    <input asp-for="Patient.Name" class="form-control" />
                    <span asp-validation-for="Patient.Name" class="text-danger"></span>
                </div>


                <div class="mb-3 ">
                    <label asp-for="Patient.BirthDate" class="form-label"></label>
                    <input asp-for="Patient.BirthDate" type="date" class="form-control" />
                    <span asp-validation-for="Patient.BirthDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Patient.Phone" class="form-label"></label>
                    <input asp-for="Patient.Phone" class="form-control" />
                    <span asp-validation-for="Patient.Phone" class="text-danger"></span>
                </div>
            </div>
                <div class="card-footer text-muted ">
                    
                </div>
        </div>
    </div>
    <div class="col-sm-6 h-100">
            <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="card-header">
                    <strong>Appointment Details</strong>
                </div>
                    <div class="mb-3">
                        <label asp-for="DoctorId" class="form-label">Doctor</label>
                        <select asp-for="DoctorId"
                                asp-items="doctorsList"
                                   class="form-select"
                                   id="doctorsDropdown"
                                    >
                            <option value="">-- Select Doctor --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AppointmentDate" class="form-label"></label>
                        <input asp-for="AppointmentDate"
                               class="form-control"
                               id="appointmentDate" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            Available Time Slots
                        </label>
                        <select class="form-select" asp-for="StartTime"
                                id="timeSlots">
                            <option value="">-- Select Time --</option>
                         </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Visit Duration</label>
                        <input type="text"
                               class="form-control"
                               value="30 Minutes"
                               readonly />
                    </div>
            </div>
        </div>
    </div>
  </div>


    <div class="text-end">
        <button type="submit" class="btn btn-success m-3">
            Save Appointment
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/Appointment.js" asp-append-version="true"></script>
}